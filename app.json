{
  "expo": {
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/spacex-logo-white.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ]
    ],
    "name": "SpaceX",
    "slug": "SpaceX"
  }
}
